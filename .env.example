# ══════════════════════════════════════════════════════
#  NyumbaLink — Master Environment Configuration
#  Copy to .env and fill in all values before deploying
#  NEVER commit .env to version control
# ══════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────
APP_ENV=production           # development | production | testing
SECRET_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_ME_DIFFERENT_32_CHAR_RANDOM_STRING
ALLOWED_HOSTS=nyumbalink.co.ke,www.nyumbalink.co.ke

# ── Domain ─────────────────────────────────────────────
SITE_URL=https://nyumbalink.co.ke
API_URL=https://nyumbalink.co.ke/api
CORS_ORIGINS=https://nyumbalink.co.ke,https://www.nyumbalink.co.ke

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nyumbalink
POSTGRES_USER=nyumbalink
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ── Elasticsearch ──────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_INDEX_PREFIX=nyumbalink

# ── Cloudinary ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=nyumbalink/properties

# ── M-Pesa ─────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENVIRONMENT=sandbox            # sandbox | production
MPESA_CALLBACK_URL=${API_URL}/payments/callback

# ── Email (SMTP) ───────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@nyumbalink.co.ke
MAIL_PASSWORD=your_app_specific_password
MAIL_DEFAULT_SENDER="NyumbaLink <noreply@nyumbalink.co.ke>"

# ── WhatsApp (Twilio) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# ── Google Maps ────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── JWT Settings ───────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES_HOURS=1
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Rate Limiting ──────────────────────────────────────
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_AUTH=10 per minute
RATELIMIT_UPLOAD=20 per hour

# ── Pagination ─────────────────────────────────────────
DEFAULT_PAGE_SIZE=12
MAX_PAGE_SIZE=50

# ── Listing Fee ────────────────────────────────────────
LISTING_FEE_KES=500

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_DIR=/app/logs
LOG_MAX_BYTES=10485760                # 10 MB
LOG_BACKUP_COUNT=5

# ── React Frontend ─────────────────────────────────────
REACT_APP_API_URL=${API_URL}
REACT_APP_GOOGLE_MAPS_API_KEY=${GOOGLE_MAPS_API_KEY}
REACT_APP_CLOUDINARY_CLOUD_NAME=${CLOUDINARY_CLOUD_NAME}
REACT_APP_SITE_NAME=NyumbaLink
REACT_APP_SITE_URL=${SITE_URL}
