{
  "version": 2,
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm ci",
  "regions": ["iad1"],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://nyumbalink-1.onrender.com/api/$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "https://nyumbalink-1.onrender.com/api/seo/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "https://nyumbalink-1.onrender.com/api/seo/robots.txt"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
